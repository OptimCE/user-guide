    },
    {
      "id": "step-2",
      "index": 2,
      "action": "wait-for",
      "interactive": false,
      "screenshotWhen": "after",
      "waitAfter": 0,
      "title": {
        "fr": "Consulter la page des notifications",
        "en": "View the notifications page"
      },
      "text": {
        "fr": "La page des notifications regroupe l'ensemble de vos notifications. On y retrouve l'invitation à rejoindre la communauté, avec le nom de la communauté et la date de réception.",
        "en": "The notifications page gathers all of your notifications. The invitation to join the community appears here, with the community name and the date it was received."
      },
      "subtitle": {
        "fr": "Toutes vos notifications",
        "en": "All your notifications"
      },
