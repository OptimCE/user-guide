{
  "version": "1.0",
  "slug": "sharing-op-inspect",
  "mode": "interactive",
  "role": "admin",
  "title": {
    "fr": "Inspecter une opération de partage",
    "en": "Inspect a sharing operation"
  },
  "locales": [
    "fr",
    "en"
  ],
  "defaultLocale": "fr",
  "layouts": [
    "desktop",
    "mobile"
  ],
  "defaultLayout": "desktop",
  "cursor": {
    "pre_action_ms": 200,
    "action_ms": 300,
    "post_action_ms": 150,
    "travel_speed_px_per_ms": 1.5
  },
  "defaultTemplate": "overlay",
  "steps": [
    {
      "id": "step-1",
      "index": 1,
      "action": "click",
      "interactive": true,
      "screenshotWhen": "before",
      "waitAfter": 0,
      "title": {
        "fr": "Ouvrir une opération",
        "en": "Open an operation"
      },
      "text": {
        "fr": "Cliquez sur la première ligne du tableau pour afficher la fiche détaillée de l'opération de partage et explorer sa configuration.",
        "en": "Click the first row of the table to open the sharing operation's detail page and inspect its configuration."
      },
      "subtitle": {
        "fr": "Liste des opérations",
        "en": "Operations list"
      },
      "captures": {
